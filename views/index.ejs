<%- include("partials/header") %>

<h1 class="text-2xl mb-6">Latest Posts</h1>

<div class="space-y-4">
  <% posts.forEach(post => { %>
    <a href="/post/<%= post.id %>" class="block bg-white p-5 rounded-xl shadow hover:shadow-md">

      <h2 class="text-lg font-semibold">
        <%= post.title %>
      </h2>

      <p class="text-gray-600 text-sm mt-2">
        <%= post.content.substring(0, 100) %>...
      </p>

    </a>
  <% }) %>
</div>

<%- include("partials/footer") %>